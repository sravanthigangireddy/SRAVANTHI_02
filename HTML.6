<!DOCTYPE html>
<html>
<head>
<title>CSS Color Reference</title>
<style>
h1{
    color: red;              /* Color name */
}

p{
    color: #00ff00;          /* Hex value */
}

h2{
    color: rgb(0,0,255);     /* RGB value */
}

h3{
    color: hsl(300, 100%, 50%);  /* HSL value */
}
</style>
</head>

<body>
<h1>This is Color Name</h1>
<p>This is HEX color</p>
<h2>This is RGB color</h2>
<h3>This is HSL color</h3>
</body>
</html>
