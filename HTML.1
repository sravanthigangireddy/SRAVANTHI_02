<!DOCTYPE html>
<html>
<head>
    <title>HTML5 Example</title>
</head>
<body>

<header>
    <h1>My Web Page</h1>
</header>

<nav>
    <a href="#">Home</a> |
    <a href="#">About</a>
</nav>

<main>
    <section>
        <h2>Section</h2>

        <article>
            <p>This is an article</p>
        </article>

        <figure>
            <img src="image.jpg" width="100">
            <figcaption>Sample Image</figcaption>
        </figure>

        <div>
            Hello <span style="color:red;">World</span>
        </div>

    </section>
</main>

<aside>
    <p>This is aside content</p>
</aside>

<footer>
    <p>Footer</p>
</footer>

</body>
</html>
